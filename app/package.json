{
	"name": "app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:start": "docker compose up -d",
		"db:push": "dotenv -e .env -- drizzle-kit push",
		"db:migrate": "dotenv -e .env -- drizzle-kit migrate",
		"db:clean": "dotenv -e .env -- tsx src/lib/server/reset-db.ts && dotenv -e .env -- drizzle-kit migrate && dotenv -e .env -- tsx src/lib/server/seed-defaults.ts && dotenv -e .env -- tsx src/lib/server/seed.ts",
		"db:seed": "dotenv -e .env -- tsx src/lib/server/seed.ts",
		"db:studio": "dotenv -e .env -- drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.3",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^24",
		"better-auth": "^1.4.3",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"postgres": "^3.4.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tsx": "^4.0.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"bring-shopping": "^2.0.1"
	}
}
