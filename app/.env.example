# Local DB (used by compose.yaml and DATABASE_URL)
DB_USER=root
DB_PASSWORD=
DB_NAME=koemerle

# Drizzle / SvelteKit
# Local dev: postgres://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}
# Production: use the DATABASE_URL from Railway
DATABASE_URL="postgres://root:your-password@localhost:5432/koemerle"

ORIGIN=""

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
