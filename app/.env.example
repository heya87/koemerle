# Local DB (used by compose.yaml and DATABASE_URL)
DB_USER=root
DB_PASSWORD=
DB_NAME=koemerle

# Drizzle / SvelteKit
# Local dev: postgres://${DB_USER}:${DB_PASSWORD}@localhost:5999/${DB_NAME}
# Production: use the DATABASE_URL from Railway
DATABASE_URL="postgres://root:your-password@localhost:5999/koemerle"

ORIGIN=""

# Fooby recipe cache TTL in minutes (default: 1440 = 24h)
# FOOBY_CACHE_TTL_MINUTES=1440

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Biogmüsabo basket sync (optional — leave empty to hide the sync button)
BIOABO_EMAIL=""
BIOABO_PASSWORD=""
